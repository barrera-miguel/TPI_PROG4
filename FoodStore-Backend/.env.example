# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://usuario:contraseña@host:puerto/nombre_base_de_datos

# ── Seguridad JWT ──────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Cambiar obligatoriamente en producción.
SECRET_KEY=clave-secreta-minimo-32-caracteres-cambiar-en-produccion
DIAS_EXPIRACION_REFRESH_TOKEN=7

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos para el frontend.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Cookies ────────────────────────────────────────────────────────────────────
# true en producción (HTTPS). false solo para desarrollo local (HTTP).
COOKIES_SECURE=true

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Límite de intentos de login. Valor recomendado en producción: 5/15minutes.
# Para desarrollo o tests se puede subir: 100/15minutes.
RATE_LIMIT_LOGIN=5/15minutes

# ── MercadoPago ────────────────────────────────────────────────────────────────
# Credenciales de prueba obtenidas en el portal de MP Developers
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# URL del webhook (requiere Ngrok activo)
MP_WEBHOOK_URL=https://xxxxxxxx.ngrok-free.app/api/v1/pagos/webhook
# Secreto para validar firma HMAC del webhook (dejar vacío para desarrollo)
MP_WEBHOOK_SECRET=

# ── Ngrok ──────────────────────────────────────────────────────────────────────
# URL pública generada por Ngrok (cambia en cada reinicio)
NGROK_URL=https://xxxxxxxx.ngrok-free.app
FRONTEND_URL=http://localhost:5173

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Credenciales obtenidas en el Dashboard de Cloudinary
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=tu-api-secret
